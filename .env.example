# Server
PORT=3000

# Core Wolfgang configuration
NAMESPACE=agent-sandbox
KUBERNETES_CLUSTER_DOMAIN=cluster.local
SANDBOX_TEMPLATE_NAME=opencode
SANDBOX_ACCESS_MODE=direct
SANDBOX_ROUTER_URL=http://sandbox-router.agent-sandbox.svc.cluster.local:8080
SANDBOX_PORT=8888
SANDBOX_IDLE_TTL_MINUTES=30
SANDBOX_READY_TIMEOUT_SECONDS=60
STATE_BACKEND_URL=redis://localhost:6379

# Optional local dev override for the Kubernetes client.
# KUBECONFIG=~/.kube/config

# Optional platform secrets. Uncomment the platforms you want to enable.

# Slack
# SLACK_SIGNING_SECRET=
# SLACK_BOT_TOKEN=
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=

# Discord
# DISCORD_PUBLIC_KEY=
# DISCORD_BOT_TOKEN=

# Telegram
# TELEGRAM_BOT_TOKEN=

# GitHub
# GITHUB_WEBHOOK_SECRET=

# Linear
# LINEAR_WEBHOOK_SECRET=

# Google Chat
# GOOGLE_CHAT_VERIFICATION_TOKEN=

# WhatsApp
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_ACCESS_TOKEN=

# Microsoft Teams
# MICROSOFT_TEAMS_APP_ID=
# MICROSOFT_TEAMS_APP_PASSWORD=
