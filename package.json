{
  "name": "agentbay",
  "version": "1.0.0",
  "description": "Chat-native orchestrator for opencode agents in Kubernetes sandboxes",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node dist/migrate.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.1.2",
      "onFail": "download"
    }
  },
  "type": "module",
  "dependencies": {
    "@chat-adapter/discord": "^4.28.1",
    "@chat-adapter/gchat": "^4.28.1",
    "@chat-adapter/github": "^4.28.1",
    "@chat-adapter/linear": "^4.28.1",
    "@chat-adapter/messenger": "^4.28.1",
    "@chat-adapter/slack": "^4.28.1",
    "@chat-adapter/state-redis": "^4.28.1",
    "@chat-adapter/teams": "^4.28.1",
    "@chat-adapter/telegram": "^4.28.1",
    "@chat-adapter/whatsapp": "^4.28.1",
    "@hono/node-server": "^2.0.2",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "@kubernetes/client-node": "^1.4.0",
    "@opencode-ai/sdk": "^1.14.50",
    "chat": "^4.28.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "pg": "^8.20.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testcontainers/k3s": "^11.14.0",
    "@types/node": "^25.8.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "testcontainers": "11.14.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
